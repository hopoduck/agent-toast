{
  "name": "agent-toast-video",
  "version": "0.1.0",
  "private": true,
  "description": "Remotion intro video for agent-toast README",
  "scripts": {
    "dev": "pnpm exec remotion studio src/Root.tsx",
    "render": "pnpm exec remotion render src/Root.tsx IntroVideo ../.github/media/intro.mp4 --codec=h264"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "lucide-react": "^1.16.0",
    "pretendard": "^1.3.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@remotion/tailwind-v4": "^4.0.462",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "ffmpeg-static": "^5.3.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@swc/core",
      "ffmpeg-static"
